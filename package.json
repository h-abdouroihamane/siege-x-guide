{
    "private": true,
    "type": "module",
    "scripts": {
        "build": "vite build",
        "build:ssr": "vite build && vite build --ssr",
        "dev": "vite",
        "format": "prettier --write resources/ app/ database/ routes/ config/ tests/",
        "format:check": "prettier --check resources/ app/ database/ routes/ config/ tests/",
        "lint": "eslint . --fix",
        "lint:check": "eslint .",
        "type-check": "vue-tsc --noEmit",
        "phpstan": "phpstan analyse --memory-limit=512M",
        "prepare": "husky"
    },
    "devDependencies": {
        "@eslint/js": "^9.19.0",
        "@prettier/plugin-php": "^0.24.0",
        "@types/node": "^22.13.5",
        "@vue/eslint-config-typescript": "^14.3.0",
        "eslint": "^9.17.0",
        "eslint-config-prettier": "^10.0.1",
        "eslint-plugin-vue": "^9.32.0",
        "husky": "^9.1.7",
        "lint-staged": "^16.2.7",
        "prettier": "^3.8.1",
        "prettier-plugin-organize-imports": "^4.1.0",
        "sass": "^1.89.1",
        "sass-embedded": "^1.89.0",
        "typescript-eslint": "^8.23.0",
        "vue-tsc": "^2.2.4"
    },
    "dependencies": {
        "@inertiajs/vue3": "^2.0.0",
        "@vitejs/plugin-vue": "^5.2.1",
        "@vueuse/core": "^12.8.2",
        "concurrently": "^9.0.1",
        "laravel-vite-plugin": "^1.0",
        "typescript": "^5.2.2",
        "vite": "^6.2.0",
        "vue": "^3.5.13",
        "ziggy-js": "^2.4.2"
    },
    "lint-staged": {
        "**/*": "prettier --write --ignore-unknown"
    }
}
